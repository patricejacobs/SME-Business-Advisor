# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Meta WhatsApp Cloud API ---
# From Meta Business > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAA...
# You invent this string; paste the same value into the Meta webhook config screen
WHATSAPP_VERIFY_TOKEN=some-long-random-string-you-choose
# Meta Business > App > Settings > Basic > App Secret. Used to verify webhook signatures.
WHATSAPP_APP_SECRET=abc123...

# --- Storage ---
DB_PATH=data/agent.db
LOG_DIR=data/logs

# --- Admin export sync ---
# You invent this string; it protects the /admin/logs endpoint used by
# `python -m app.export pull` to bring completed intakes down to your machine.
# Same value must be set here AND in your Render deployment's env vars.
ADMIN_API_KEY=another-long-random-string-you-choose

# --- Behaviour ---
# Set to 1 to skip signature verification during local testing. NEVER in production.
ALLOW_UNSIGNED_WEBHOOKS=0
